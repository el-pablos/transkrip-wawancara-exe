# ============================================================
# .env.example — Contoh environment variables
# Copy jadi .env dan isi nilainya (JANGAN commit .env!)
# ============================================================

# --- Redis Cache (opsional, kalau tidak diset = fallback tanpa cache) ---
REDIS_HOST=
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_DB=0

# --- Cache TTL (detik, default 30 hari) ---
CACHE_TTL_SECONDS=2592000

# --- FFmpeg (opsional, kalau sudah di PATH tidak perlu) ---
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
# FFPROBE_PATH=C:\path\to\ffprobe.exe

# --- GitHub Token (HANYA untuk gh CLI login, JANGAN commit!) ---
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
